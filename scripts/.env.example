# PicoGuard 環境設定範例
# 複製此檔案為 .env 並填入實際值

# 環境模式: development, production, testing
ENVIRONMENT=development
DEBUG=true

# 伺服器設定
HOST=0.0.0.0
PORT=8000

# 資料庫設定
DATABASE_URL=sqlite:///./picoguard.db

# 安全性設定
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 裝置通訊
DEVICE_API_KEY=pico-device-key
